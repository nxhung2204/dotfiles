{
  "env": {},
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -title \"✅ $(basename \"$PWD\")\" -message 'CC - Task done' -sound default"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -title \"🔔 $(basename \"$PWD\")\" -message 'CC - Need user input' -sound Basso"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /Users/rightsvn-hung/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "cc-auto-workflow": {
      "source": {
        "source": "git",
        "url": "https://github.com/nxhung2304/cc-auto-workflow-plugin.git"
      }
    },
    "auto-workflow": {
      "source": {
        "source": "github",
        "repo": "nxhung2304/cc-auto-workflow-plugin"
      }
    }
  },
  "effortLevel": "medium",
  "autoMemoryEnabled": false,
  "model": "opus"
}
